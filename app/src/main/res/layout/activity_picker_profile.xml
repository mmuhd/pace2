<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFDFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/backButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_dark"
                    android:textStyle="bold"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/profileMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_dark_50"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/brand_dark_50"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Basic Information"
                    android:textStyle="bold"
                    android:textColor="@color/brand_dark"
                    android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nickname" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueNickname" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phone" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valuePhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ID Number" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueIdNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/brand_dark_50"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Location &amp; Cluster" android:textStyle="bold" android:textColor="@color/brand_dark" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LGA" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueLga" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Community" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueCommunity" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cluster" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueCluster" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Primary Collection Location" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valuePrimaryLocation" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/brand_dark_50"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Work Profile" android:textStyle="bold" android:textColor="@color/brand_dark" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Waste Types" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueWasteTypes" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Years Picking" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueYears" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Selling Mode" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueSellingMode" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Income Range" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueIncomeRange" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/brand_dark_50"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safety &amp; Formalisation" android:textStyle="bold" android:textColor="@color/brand_dark" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PPE Usage" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valuePpeUsage" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Had Training" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueTraining" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Training Provider" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueTrainingProvider" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Willing to Join Formal System" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueWillingJoin" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Special Needs / Comments" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/valueSpecialNeeds" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>

