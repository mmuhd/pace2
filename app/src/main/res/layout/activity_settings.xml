<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFDFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/backButton" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_back" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:id="@+id/profileName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="20sp" />
                <TextView android:id="@+id/profileMeta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView android:id="@+id/sectionAccount" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:strokeColor="@color/brand_dark_50" app:strokeWidth="1dp" app:cardBackgroundColor="@android:color/white" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Account" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="16sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Full name" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
                    <com.google.android.material.textfield.TextInputEditText android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton android:id="@+id/logoutBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Logout" android:textAllCaps="false" android:layout_marginTop="8dp" app:cornerRadius="8dp" style="@style/Widget.MaterialComponents.Button" android:backgroundTint="@color/brand_dark" android:textColor="@android:color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:id="@+id/sectionLanguage" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:strokeColor="@color/brand_dark_50" app:strokeWidth="1dp" app:cardBackgroundColor="@android:color/white" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Language &amp; Accessibility" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Language" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
                <Spinner android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:popupBackground="@android:color/white" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Text size" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
                <Spinner android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:popupBackground="@android:color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:id="@+id/sectionDataSync" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:strokeColor="@color/brand_dark_50" app:strokeWidth="1dp" app:cardBackgroundColor="@android:color/white" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data &amp; Sync" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="16sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Offline mode" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
                <Switch android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <com.google.android.material.button.MaterialButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sync now" android:textAllCaps="false" android:layout_marginTop="8dp" app:cornerRadius="8dp" style="@style/Widget.MaterialComponents.Button" android:backgroundTint="@color/brand_green" android:textColor="@android:color/white" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Backend API URL" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="12dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/apiBaseUrlEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="e.g. http://10.0.2.2:8000/api" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton android:id="@+id/saveApiBaseUrlBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Save API URL" android:textAllCaps="false" android:layout_marginTop="8dp" app:cornerRadius="8dp" style="@style/Widget.MaterialComponents.Button" android:backgroundTint="@color/brand_dark" android:textColor="@android:color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:id="@+id/sectionNotifications" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:strokeColor="@color/brand_dark_50" app:strokeWidth="1dp" app:cardBackgroundColor="@android:color/white" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notifications" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="16sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Follow-ups due" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
                <Switch android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:id="@+id/sectionPrivacy" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:strokeColor="@color/brand_dark_50" app:strokeWidth="1dp" app:cardBackgroundColor="@android:color/white" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Security &amp; Privacy" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="16sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="App lock (PIN)" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
                <Switch android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:id="@+id/sectionSupport" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:strokeColor="@color/brand_dark_50" app:strokeWidth="1dp" app:cardBackgroundColor="@android:color/white" android:layout_marginTop="12dp" android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Support" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="16sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Contact support: +234-XXX-XXXX" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
