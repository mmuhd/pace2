<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCFDFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/backButton" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_back" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Waste Evacuation Pickup" android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="20sp" android:layout_marginStart="12dp" />
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Source type" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="12dp" />
        <Spinner android:id="@+id/sourceTypeSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:popupBackground="@android:color/white" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Vehicle type" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <Spinner android:id="@+id/vehicleTypeSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:popupBackground="@android:color/white" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Wheel config" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <Spinner android:id="@+id/wheelConfigSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:popupBackground="@android:color/white" />
        <TextView android:id="@+id/capacityHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/brand_dark_50" android:textSize="12sp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Source name" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/sourceNameEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="LGA" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <Spinner android:id="@+id/lgaSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:popupBackground="@android:color/white" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Address" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/addressEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Scheduled time window" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/scheduledEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="e.g. Today 10:00–14:00" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Assigned driver/team" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/assignedEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Total load (kg)" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/totalKgEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mini characterization (kg)" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="12dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Plastic" android:textColor="@color/brand_dark" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/kgPlastic" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Paper/Cardboard" android:textColor="@color/brand_dark" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/kgPaper" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Metal" android:textColor="@color/brand_dark" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/kgMetal" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Glass" android:textColor="@color/brand_dark" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/kgGlass" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Organic" android:textColor="@color/brand_dark" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/kgOrganic" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Other" android:textColor="@color/brand_dark" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/kgOther" android:layout_width="80dp" android:layout_height="wrap_content" android:inputType="numberDecimal" android:background="@drawable/spinner_bg" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/estimateBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Apply 30% recyclable / 70% organic" android:textAllCaps="false" android:layout_marginTop="8dp" app:cornerRadius="8dp" style="@style/Widget.MaterialComponents.Button" android:backgroundTint="@color/brand_dark" android:textColor="@android:color/white" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Contamination score (0–100)" android:textColor="@color/brand_dark" android:textSize="12sp" android:layout_marginTop="8dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundMode="none">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/contamEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:background="@drawable/spinner_bg" android:textColor="@color/brand_dark" android:textColorHint="@color/brand_dark_50" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/saveBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Save Pickup" android:textAllCaps="false" android:layout_marginTop="12dp" app:cornerRadius="8dp" style="@style/Widget.MaterialComponents.Button" android:backgroundTint="@color/brand_green" android:textColor="@android:color/white" />
    </LinearLayout>
</ScrollView>
